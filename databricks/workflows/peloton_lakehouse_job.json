{
  "name": "Peloton Lakehouse Pipeline",
  "max_concurrent_runs": 1,
  "environments": [
    {
      "environment_key": "default",
      "spec": {
        "client": "2",
        "dependencies": [
          "requests>=2.32.0",
          "pandas>=2.2.0",
          "pydantic>=2.7.0",
          "pydantic-settings>=2.3.0",
          "scikit-learn>=1.5.0",
          "numpy>=1.26.0",
          "joblib>=1.4.0",
          "mlflow>=2.16.0"
        ]
      }
    }
  ],
  "tasks": [
    {
      "task_key": "01_setup",
      "environment_key": "default",
      "notebook_task": {
        "notebook_path": "/Users/<user>/peloton-analytics-databricks/databricks/notebooks/00_setup",
        "base_parameters": {
          "repo_root": "/Users/<user>/peloton-analytics-databricks",
          "catalog": "main",
          "schema": "fitness",
          "artifact_base_path": "/dbfs/FileStore/peloton_analytics",
          "peloton_since": "",
          "peloton_max_workouts": "150"
        }
      }
    },
    {
      "task_key": "02_ingestion",
      "depends_on": [
        {
          "task_key": "01_setup"
        }
      ],
      "environment_key": "default",
      "notebook_task": {
        "notebook_path": "/Users/<user>/peloton-analytics-databricks/databricks/notebooks/01_data_ingestion",
        "base_parameters": {
          "repo_root": "/Users/<user>/peloton-analytics-databricks",
          "catalog": "main",
          "schema": "fitness",
          "peloton_since": "",
          "peloton_max_workouts": "150",
          "peloton_secret_scope": "peloton",
          "peloton_username_key": "username",
          "peloton_password_key": "password"
        }
      }
    },
    {
      "task_key": "03_governance",
      "depends_on": [
        {
          "task_key": "02_ingestion"
        }
      ],
      "environment_key": "default",
      "notebook_task": {
        "notebook_path": "/Users/<user>/peloton-analytics-databricks/databricks/notebooks/02_data_governance",
        "base_parameters": {
          "catalog": "main",
          "schema": "fitness"
        }
      }
    },
    {
      "task_key": "04_bi",
      "depends_on": [
        {
          "task_key": "03_governance"
        }
      ],
      "environment_key": "default",
      "notebook_task": {
        "notebook_path": "/Users/<user>/peloton-analytics-databricks/databricks/notebooks/03_bi",
        "base_parameters": {
          "repo_root": "/Users/<user>/peloton-analytics-databricks",
          "catalog": "main",
          "schema": "fitness"
        }
      }
    },
    {
      "task_key": "05_ml",
      "depends_on": [
        {
          "task_key": "04_bi"
        }
      ],
      "environment_key": "default",
      "notebook_task": {
        "notebook_path": "/Users/<user>/peloton-analytics-databricks/databricks/notebooks/04_ml",
        "base_parameters": {
          "repo_root": "/Users/<user>/peloton-analytics-databricks",
          "catalog": "main",
          "schema": "fitness",
          "artifact_base_path": "/dbfs/FileStore/peloton_analytics",
          "mlflow_enabled": "true",
          "mlflow_experiment_name": "/Users/<user>/peloton-analytics",
          "mlflow_run_name": "peloton-ml-training",
          "mlflow_registered_model_name": ""
        }
      }
    }
  ]
}
