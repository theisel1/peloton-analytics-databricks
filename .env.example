# Peloton credentials
PELOTON_USERNAME=you@example.com
PELOTON_PASSWORD=your-password

# Optional: only load workouts after this date (UTC)
# Example: 2024-01-01T00:00:00Z
PELOTON_SINCE=
# Optional: limit number of latest workouts pulled (helps first run complete faster)
PELOTON_MAX_WORKOUTS=
# Optional: write raw/processed files to local disk (default false)
WRITE_LOCAL_STAGING=false

# Databricks SQL Warehouse connection
# Required for SQL API mode (local execution)
DATABRICKS_SERVER_HOSTNAME=adb-xxxxxxxxxxxxxxxx.x.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxx
DATABRICKS_ACCESS_TOKEN=dapiXXXXXXXXXXXXXXXX

# Databricks-native mode (inside Databricks job/cluster)
USE_DATABRICKS_SPARK=true
# ML artifacts path in Databricks Filesystem
DATABRICKS_ARTIFACT_BASE_PATH=/dbfs/FileStore/peloton_analytics
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=fitness
